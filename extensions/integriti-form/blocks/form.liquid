{% if block.settings.form_id != blank %}
<div
  class="integriti-form-block"
  data-integriti-form-id="{{ block.settings.form_id }}"
  data-shop="{{ shop.permanent_domain }}"
  {{ block.shopify_attributes }}
></div>
<script src="{{ 'embed.js' | asset_url }}" defer></script>
{% else %}
<div {{ block.shopify_attributes }} style="padding:16px;border:1px solid #ccc;color:#666;font-size:14px;">
  Enter a Form ID in the block settings.
</div>
{% endif %}

{% schema %}
{
  "name": "FormEase Form",
  "target": "section",
  "settings": [
    {
      "type": "text",
      "id": "form_id",
      "label": "Form ID",
      "info": "Paste the Form ID from your FormEase app."
    }
  ]
}
{% endschema %}
